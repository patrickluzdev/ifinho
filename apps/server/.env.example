# URL de conexão com o PostgreSQL
# Dev local: postgresql://USER:PASSWORD@localhost:5432/DB
# Prod (Docker): definido automaticamente pelo docker-compose
DATABASE_URL=postgresql://ifinho:change_me@localhost:5432/ifinho

# Origem permitida pelo CORS (URL do frontend)
CORS_ORIGIN=http://localhost:5173

# Endpoint do Ollama
# Dev local: http://localhost:11434
# Prod (Docker): http://ifinho-ollama:11434
OLLAMA_BASE_URL=http://localhost:11434
# Modelo Ollama a usar (ex: llama3.2:3b, llama3.1:8b)
OLLAMA_MODEL=llama3.2:3b

NODE_ENV=development
